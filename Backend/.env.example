# Configurações do Servidor
PORT=3000
NODE_ENV=development

# Configurações do Banco de Dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=kontrollapro
DB_USER=root
DB_PASSWORD=SUA_SENHA_DO_BANCO_AQUI

# Configurações de Autenticação
JWT_SECRET=SEU_JWT_SECRET_AQUI
JWT_EXPIRES_IN=24h

# Configurações de Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Configurações de Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Configurações de CORS
CORS_ORIGIN=http://localhost:5173

# Configurações de Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=SEU_EMAIL_DE_ENVIO_AQUI
EMAIL_PASS=SUA_SENHA_DE_APP_AQUI

# Configurações de NF-e (opcional)
NFE_CERTIFICADO_PATH=./certificados/certificado.pfx
NFE_CERTIFICADO_PASSWORD=SENHA_DO_CERTIFICADO_AQUI
NFE_AMBIENTE=homologacao

# Configurações da Focus NFe
# Token Principal (Master) - Fixo no sistema, usado para gerenciar empresas via API
# Obtenha em: https://app.focusnfe.com.br/ > Painel API > Token principal produção
FOCUS_NFE_TOKEN_PRINCIPAL=SEU_FOCUS_NFE_TOKEN_AQUI

# Configurações do MeuDanfe (consulta NF-e)
# Documentação: https://meudanfe.com.br/api
MEUDANFE_API_KEY=SUA_MEUDANFE_API_KEY_AQUI
MEUDANFE_API_URL=https://api.meudanfe.com.br/v2/fd

# Configurações do Cloudinary
CLOUDINARY_CLOUD_NAME=SEU_CLOUDINARY_CLOUD_NAME_AQUI
CLOUDINARY_API_KEY=SUA_CLOUDINARY_API_KEY_AQUI
CLOUDINARY_API_SECRET=SEU_CLOUDINARY_API_SECRET_AQUI

# Configurações do Google OAuth
GOOGLE_CLIENT_ID=SEU_GOOGLE_CLIENT_ID_AQUI
GOOGLE_CLIENT_SECRET=SEU_GOOGLE_CLIENT_SECRET_AQUI
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# =================================================================
# STRIPE (ASSINATURAS / PLANOS)
# =================================================================
# Docs: https://docs.stripe.com/api
STRIPE_SECRET_KEY=SUA_STRIPE_SECRET_KEY_AQUI
STRIPE_WEBHOOK_SECRET=SEU_STRIPE_WEBHOOK_SECRET_AQUI

# Price IDs (um por plano)
STRIPE_PRICE_STARTER=SEU_STRIPE_PRICE_STARTER_ID_AQUI
STRIPE_PRICE_PROFESSIONAL=SEU_STRIPE_PRICE_PROFESSIONAL_ID_AQUI
STRIPE_PRICE_ENTERPRISE=SEU_STRIPE_PRICE_ENTERPRISE_ID_AQUI

# URLs de retorno do Checkout
STRIPE_SUCCESS_URL=http://localhost:5173/dashboard?stripe=success
STRIPE_CANCEL_URL=http://localhost:5173/signup?stripe=cancel

# Billing Portal
STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:5173/dashboard/configuracoes?aba=assinatura