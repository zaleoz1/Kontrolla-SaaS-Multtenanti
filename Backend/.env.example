# =================================================================
# KONTROLLAPRO BACKEND - EXEMPLO DE VARIÁVEIS DE AMBIENTE
# =================================================================
# Copie para `Backend/.env` e preencha com seus valores.
#
# IMPORTANTE: não comite chaves reais em `.env`.

# Servidor
PORT=3000
NODE_ENV=development

# Banco
DB_HOST=localhost
DB_PORT=3306
DB_NAME=kontrollapro
DB_USER=root
DB_PASSWORD=change_me

# Auth
JWT_SECRET=change_me_super_secure
JWT_EXPIRES_IN=24h

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@example.com
EMAIL_PASS=change_me

# NF-e / Integrações
FOCUS_NFE_TOKEN_PRINCIPAL=change_me
MEUDANFE_API_KEY=change_me
MEUDANFE_API_URL=https://api.meudanfe.com.br/v2/fd

# Cloudinary
CLOUDINARY_CLOUD_NAME=change_me
CLOUDINARY_API_KEY=change_me
CLOUDINARY_API_SECRET=change_me

# Google OAuth
GOOGLE_CLIENT_ID=change_me
GOOGLE_CLIENT_SECRET=change_me
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# =================================================================
# STRIPE (ASSINATURAS / PLANOS)
# =================================================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PROFESSIONAL=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

STRIPE_SUCCESS_URL=http://localhost:5173/dashboard?stripe=success
STRIPE_CANCEL_URL=http://localhost:5173/signup?stripe=cancel
STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:5173/dashboard/configuracoes?aba=assinatura

